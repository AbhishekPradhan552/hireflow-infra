generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String               @id @default(uuid())
  email       String               @unique
  password    String
  createdAt   DateTime             @default(now())
  memberships OrganizationMember[]
}


model Job {
  id                 String       @id @default(uuid())
  title              String
  description        String?
  status             JobStatus       @default(OPEN)
  createdAt          DateTime     @default(now())
  orgId              String
  requiredSkills     String[]     @default([])
  aiStatus           JobAIStatus  @default(PENDING)
  embedding          Float[]      @default([])
  embeddingModel     String?
  embeddingUpdatedAt DateTime?
  candidates         Candidate[]
  org                Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

enum JobStatus {
  OPEN
  CLOSED
}

model Candidate {
  id           String          @id @default(uuid())
  name         String
  email        String
  phone        String?
  createdAt    DateTime        @default(now())
  jobId        String
  orgId        String
  bestResumeId String?
  bestScore    Int?
  status       CandidateStatus @default(APPLIED)
  job          Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  org          Organization    @relation(fields: [orgId], references: [id])
  resumes      Resume[]

  @@unique([jobId, email])
  @@index([jobId])
  @@index([orgId])
  @@index([jobId, status])
}

model Organization {
  id           String                    @id @default(uuid())
  name         String
  createdAt    DateTime                  @default(now())
  candidates   Candidate[]
  jobs         Job[]
  usages       OrgUsage[]
  members      OrganizationMember[]
  subscription OrganizationSubscription?
  resumes      Resume[]

  invites OrganizationInvite[]
}

model OrganizationMember {
  id        String       @id @default(uuid())
  role      OrgRole
  createdAt DateTime     @default(now())
  userId    String
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@unique([userId, orgId])
  @@index([orgId])
}

model Resume {
  id                 String            @id @default(cuid())
  fileSize           Int
  mimeType           String
  candidateId        String
  orgId              String
  uploadedBy         String
  parseStatus        ResumeParseStatus @default(PENDING)
  createdAt          DateTime          @default(now())
  originalName       String
  parseError         String?
  parsedAt           DateTime?
  parsedData         Json?
  parsedText         String?
  confidenceScore    Int?
  scoreBreakdown     Json?
  matchScore         Int?
  matchedSkills      String[]
  missingSkills      String[]
  aiProcessedAt      DateTime?
  aiStatus           ResumeAIStatus    @default(PENDING)
  embedding          Float[]           @default([])
  embeddingCreatedAt DateTime?
  embeddingModel     String?
  hybridScore        Int?
  semanticRawScore   Float?
  semanticScore      Int?
  fileKey            String
  aiSummary          String?
  candidate          Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  org                Organization      @relation(fields: [orgId], references: [id])

  @@index([candidateId])
  @@index([orgId])
  @@index([semanticScore])
  @@index([hybridScore])
}

model OrgUsage {
  id            String       @id @default(uuid())
  orgId         String
  month         String
  resumesParsed Int          @default(0)
  jobsCreated   Int          @default(0)
  org           Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, month])
  @@index([orgId])
}

model OrganizationSubscription {
  id                     String             @id @default(uuid())
  orgId                  String             @unique
  plan                   BillingPlan        @default(FREE)
  status                 SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  provider               String             @default("razorpay")
  providerCustomerId     String?            @unique
  providerSubscriptionId String?            @unique
  lastWebhookAt          DateTime?
  lastWebhookEvent       String?
  org                    Organization       @relation(fields: [orgId], references: [id])
}

model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@index([name])
}

model OrganizationInvite {
  id        String   @id @default(uuid())

  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  token     String   @unique
  email     String?
  role      OrgRole  @default(RECRUITER)

  createdAt DateTime @default(now())
  expiresAt DateTime
  usedAt    DateTime?
  usedBy    String? // userId

  @@index([orgId])
  @@index([email])
}

enum OrgRole {
  OWNER
  ADMIN
  RECRUITER
  VIEWER
}

enum ResumeParseStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BillingPlan {
  FREE
  PRO
  TEAM
}

enum SubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum ResumeAIStatus {
  PENDING
  EMBEDDING
  SCORING
  COMPLETED
  FAILED
}

enum JobAIStatus {
  PENDING
  EMBEDDING
  COMPLETED
  FAILED
}

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}
